<script>
  const search = document.getElementById('cmdSearch');
  search.addEventListener('input', () => {
    const q = search.value.toLowerCase().trim();
    document.querySelectorAll('.cmd-item').forEach(item => {
      item.classList.toggle('hidden', q !== '' && !item.textContent.toLowerCase().includes(q));
    });
    document.querySelectorAll('.cmd-category').forEach(cat => {
      const visible = cat.querySelectorAll('.cmd-item:not(.hidden)').length;
      cat.style.display = visible === 0 && q !== '' ? 'none' : '';
    });
  });
</script>
