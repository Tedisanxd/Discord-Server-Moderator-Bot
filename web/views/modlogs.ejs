<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Mod Logs — <%= guild.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script>(function(){try{document.documentElement.setAttribute('data-theme',localStorage.getItem('theme')||'dark')}catch(e){}})()</script>
</head>
<body><div class="page-wrapper">

<nav class="navbar"><div class="nav-inner">
  <a href="/" class="nav-brand"><span class="nav-logo">⚡</span><span class="nav-name">tedisanxd</span></a>
  <div class="nav-links">
    <a href="/" class="nav-link">Home</a>
    <a href="/commands" class="nav-link">Commands</a>
    <a href="/status" class="nav-link">Status</a>
    <a href="/roadmap" class="nav-link">Roadmap</a>
    <a href="/suggestions" class="nav-link">Suggestions</a>
  </div>
  <div class="nav-right">
    <div class="theme-switcher">
      <button class="theme-btn" id="themeToggle" title="Change theme">🎨</button>
      <div class="theme-dropdown" id="themeDropdown">
        <div class="theme-option" data-theme="dark">🌙 Dark</div>
        <div class="theme-option" data-theme="amoled">⚫ AMOLED</div>
        <div class="theme-option" data-theme="midnight">🌌 Midnight</div>
        <div class="theme-option" data-theme="slate">💜 Slate</div>
        <div class="theme-option" data-theme="light">☀️ Light</div>
      </div>
    </div>
    <% if (user) { %>
      <div class="nav-user">
        <img class="nav-avatar" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt="">
        <span class="nav-username"><%= user.username %></span>
      </div>
      <a href="/guilds" class="btn btn-primary btn-sm">My Servers</a>
      <a href="/auth/logout" class="btn btn-ghost btn-sm">Logout</a>
    <% } else { %>
      <a href="/auth/discord" class="btn btn-primary btn-sm">Login with Discord</a>
    <% } %>
  </div>
</div></nav>

<div class="container">
  <div class="dash-layout">
    <div class="sidebar">
      <div class="sidebar-section">Navigation</div>
      <a href="/dashboard/<%= guild.id %>" class="sidebar-item"><span class="sicon">⚙️</span> Overview</a>
      <a href="/dashboard/<%= guild.id %>/modlogs" class="sidebar-item active"><span class="sicon">📋</span> Mod Logs</a>
      <div class="sidebar-section" style="margin-top:8px">Server</div>
      <a href="https://discord.com/channels/<%= guild.id %>" target="_blank" class="sidebar-item"><span class="sicon">🔗</span> Open in Discord</a>
      <a href="/guilds" class="sidebar-item"><span class="sicon">←</span> All Servers</a>
    </div>

    <div>
      <div class="section-header">
        <div><div class="page-title">📋 Mod Logs</div><div class="page-subtitle"><%= total %> total cases</div></div>
        <a href="/dashboard/<%= guild.id %>" class="btn btn-ghost btn-sm">← Back</a>
      </div>

      <div class="card" style="padding:0;overflow:hidden">
        <% if (cases.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h3>No mod actions yet</h3>
            <p>Mod actions will appear here once moderators take action on members.</p>
          </div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead><tr><th>#</th><th>Type</th><th>User</th><th>Moderator</th><th>Reason</th><th>Date</th></tr></thead>
            <tbody>
              <% for (const c of cases) { %>
              <tr>
                <td style="color:var(--muted);font-weight:600">#<%= c.case_number %></td>
                <td><span class="badge badge-<%= c.type %>"><%= c.type.toUpperCase() %></span></td>
                <td><div style="font-weight:500"><%= c.user_tag %></div><div style="font-size:12px;color:var(--muted)"><%= c.user_id %></div></td>
                <td><div style="font-weight:500"><%= c.moderator_tag %></div><div style="font-size:12px;color:var(--muted)"><%= c.moderator_id %></div></td>
                <td style="max-width:260px;color:var(--text-secondary)"><%= c.reason %><% if(c.duration){%> <span style="color:var(--muted);font-size:12px">(<%= c.duration %>)</span><%}%></td>
                <td style="color:var(--muted);white-space:nowrap;font-size:13px"><%= new Date(c.timestamp).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}) %></td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <div class="pagination">
        <% if (page > 0) { %><a href="?page=<%= page-1 %>" class="btn btn-ghost btn-sm">← Prev</a><% } %>
        <span class="btn btn-ghost btn-sm" style="cursor:default">Page <%= page+1 %> of <%= Math.ceil(total/perPage)||1 %></span>
        <% if ((page+1)*perPage < total) { %><a href="?page=<%= page+1 %>" class="btn btn-ghost btn-sm">Next →</a><% } %>
      </div>
    </div>
  </div>
</div>

<footer><div class="footer-inner">
  <div style="display:flex;align-items:center;gap:8px;font-weight:700;color:var(--text-secondary)"><span>⚡</span> tedisanxd</div>
  <div class="footer-links"><a href="/commands">Commands</a><a href="/status">Status</a><a href="/roadmap">Roadmap</a><a href="/suggestions">Suggestions</a><a href="/license">License</a></div>
  <div style="color:var(--muted)">© 2025 tedisanxd. All rights reserved.</div>
</div></footer>
<script src="/js/app.js"></script>
</div></body></html>
