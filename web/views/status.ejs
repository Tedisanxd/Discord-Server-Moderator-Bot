<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Bot Status</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script>(function(){try{document.documentElement.setAttribute('data-theme',localStorage.getItem('theme')||'dark')}catch(e){}})()</script>
</head>
<body><div class="page-wrapper">

<nav class="navbar"><div class="nav-inner">
  <a href="/" class="nav-brand"><span class="nav-logo">⚡</span><span class="nav-name">tedisanxd</span></a>
  <div class="nav-links">
    <a href="/" class="nav-link">Home</a>
    <a href="/commands" class="nav-link">Commands</a>
    <a href="/status" class="nav-link active">Status</a>
    <a href="/roadmap" class="nav-link">Roadmap</a>
    <a href="/suggestions" class="nav-link">Suggestions</a>
  </div>
  <div class="nav-right">
    <div class="theme-switcher">
      <button class="theme-btn" id="themeToggle" title="Change theme">🎨</button>
      <div class="theme-dropdown" id="themeDropdown">
        <div class="theme-option" data-theme="dark">🌙 Dark</div>
        <div class="theme-option" data-theme="amoled">⚫ AMOLED</div>
        <div class="theme-option" data-theme="midnight">🌌 Midnight</div>
        <div class="theme-option" data-theme="slate">💜 Slate</div>
        <div class="theme-option" data-theme="light">☀️ Light</div>
      </div>
    </div>
    <% if (user) { %>
      <div class="nav-user">
        <img class="nav-avatar" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt="">
        <span class="nav-username"><%= user.username %></span>
      </div>
      <a href="/guilds" class="btn btn-primary btn-sm">My Servers</a>
      <a href="/auth/logout" class="btn btn-ghost btn-sm">Logout</a>
    <% } else { %>
      <a href="/auth/discord" class="btn btn-primary btn-sm">Login with Discord</a>
    <% } %>
  </div>
</div></nav>

<div class="status-hero">
  <div class="status-indicator">
    <div class="status-dot <%= online ? '' : 'offline' %>"></div>
    <span><%= online ? 'All Systems Operational' : 'Bot Offline' %></span>
  </div>
  <div style="color:var(--muted);font-size:14px;margin-top:10px">Last checked: just now</div>
</div>

<div class="container-sm">
  <div class="status-grid">
    <div class="status-card"><div class="status-card-icon">🌐</div><div class="status-card-value text-accent"><%= guildCount %></div><div class="status-card-label">Servers</div></div>
    <div class="status-card"><div class="status-card-icon">👥</div><div class="status-card-value"><%= userCount %></div><div class="status-card-label">Users</div></div>
    <div class="status-card"><div class="status-card-icon">⏱️</div><div class="status-card-value" style="font-size:18px;padding-top:6px"><%= uptime %></div><div class="status-card-label">Uptime</div></div>
    <div class="status-card"><div class="status-card-icon">📡</div><div class="status-card-value" style="color:<%= ping<100?'var(--success)':ping<250?'var(--warn)':'var(--danger)' %>"><%= ping %>ms</div><div class="status-card-label">API Latency</div></div>
  </div>

  <div class="card">
    <div class="card-title">⚡ Service Status</div>
    <table>
      <thead><tr><th>Service</th><th>Status</th><th>Details</th></tr></thead>
      <tbody>
        <tr><td style="font-weight:600">Discord Gateway</td><td><span class="badge badge-<%= online?'success':'ban' %>"><%= online?'Operational':'Down' %></span></td><td style="color:var(--muted)">WebSocket connection</td></tr>
        <tr><td style="font-weight:600">Database</td><td><span class="badge badge-success">Operational</span></td><td style="color:var(--muted)">SQLite — local</td></tr>
        <tr><td style="font-weight:600">Web Dashboard</td><td><span class="badge badge-success">Operational</span></td><td style="color:var(--muted)">Express.js server</td></tr>
        <tr><td style="font-weight:600">AutoMod</td><td><span class="badge badge-success">Operational</span></td><td style="color:var(--muted)">Filtering active</td></tr>
        <tr><td style="font-weight:600">Moderation</td><td><span class="badge badge-success">Operational</span></td><td style="color:var(--muted)"><%= caseCount %> total cases logged</td></tr>
      </tbody>
    </table>
  </div>

  <div class="card" style="text-align:center;padding:32px">
    <div style="font-size:32px;margin-bottom:12px">📊</div>
    <div style="font-weight:700;font-size:16px;margin-bottom:6px">All systems running smoothly</div>
    <div style="color:var(--muted);font-size:14px">No incidents reported.</div>
  </div>
</div>

<footer><div class="footer-inner">
  <div style="display:flex;align-items:center;gap:8px;font-weight:700;color:var(--text-secondary)"><span>⚡</span> tedisanxd</div>
  <div class="footer-links"><a href="/commands">Commands</a><a href="/status">Status</a><a href="/roadmap">Roadmap</a><a href="/suggestions">Suggestions</a><a href="/license">License</a></div>
  <div style="color:var(--muted)">© 2025 tedisanxd. All rights reserved.</div>
</div></footer>
<script src="/js/app.js"></script>
</div></body></html>
