  <!-- About -->
  <div class="section-block">
    <h2>👤 About the Author</h2>
    <div class="card" style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">
      <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#a78bfa);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:800;color:#fff;flex-shrink:0">T</div>
      <div style="flex:1">
        <div style="font-size:18px;font-weight:800;margin-bottom:4px">tedisanxd</div>
